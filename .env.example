# 必填
DEEPSEEK_API_KEY=

# 模型配置
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_THINKING_TYPE=enabled
DEEPSEEK_REASONING_EFFORT=medium
DEEPSEEK_STREAM=true
AMADEUS_MAX_TURNS=8

# Skill 路径
SKILL_AGENT_MD_REL=./skills/agent.md
SKILL_ROOT_REL=./skills

# Agent Server
AGENT_SERVER_ADDR=:9000
AGENT_SERVER_URL=http://localhost:9000

# NapCat
NAPCAT_API_URL=http://127.0.0.1:3000
NAPCAT_TOKEN=2A1NhvoxT6a1.Hk9
QQ_BOT_ID=

# RAG 记忆（可选，不配置时 search_memory 工具静默降级）
# OpenAI Embedding API（用于将对话内容向量化）
OPENAI_EMBEDDING_API_KEY=
OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Milvus 向量数据库（使用 docker-compose.milvus.yml 一键启动）
MILVUS_ADDRESS=localhost:19530
MILVUS_COLLECTION=amadeus_memory
